generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Contact / quote submissions: `type` discriminates the JSON shape.
/// For type "inquiry" (contact form), `payload` holds: reason, name, email, company?, phone?, message?
model Lead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type      String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([type], map: "idx_leads_type")
  @@index([createdAt(sort: Desc)], map: "idx_leads_created_at")
  @@map("leads")
}
