# Vendure Shop API (browser and server). For local dev without Docker, use http://localhost:3000/shop-api
NEXT_PUBLIC_VENDURE_SHOP_API_URL=http://localhost:3000/shop-api

# --- Staff ops portal ---
# Production (DigitalOcean App Platform): staff use HTTPS on the internet, e.g. https://ops.yourdomain.com
# Set on DO as BUILD_TIME: NEXT_PUBLIC_OPS_HOST=ops.yourdomain.com (same value as INTERNAL_OPS_HOST at runtime).
# Do not use localhost:3001 — that port is only inside the Docker container (nginx → Next).
#
# Local Next dev (pnpm dev, default port 3003): optional ops testing
# NEXT_PUBLIC_OPS_HOST=localhost
#
# Optional alternate local hostname (add to hosts file): ops.example.test → 127.0.0.1
# NEXT_PUBLIC_OPS_HOST=ops.example.test
#
# Clerk (ops host only in app code): BUILD_TIME publishable + RUN_TIME secret on DO — see deploy/env.production.example
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# CLERK_SECRET_KEY=sk_test_xxx
# Absolute sign-in URL (recommended production): https://ops.yourdomain.com/ops/sign-in
# Local dev with pnpm (port 3003): http://localhost:3003/ops/sign-in
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://ops.yourdomain.com/ops/sign-in
# Clerk satellite / multi-domain (only if your Clerk instance requires them — see dashboard):
# NEXT_PUBLIC_CLERK_IS_SATELLITE=true
# NEXT_PUBLIC_CLERK_DOMAIN=ops.yourdomain.com
# VENDURE_SHOP_API_URL is set by Docker for server-side requests (storefront container → vendure)
# Server-only (Docker / .env): per-request Shop API timeout from API routes — avoids nginx 504 when Vendure is slow (default 30000 in compose).
# VENDURE_SERVER_FETCH_TIMEOUT_MS=30000

# Optional: taxed “gift box” fee as a real order line (create a Gift box product in Vendure Admin, Standard tax, $3.99; paste variant ID).
# Gift add-on: no variant ID — surcharge is set on the order + Stripe PI (see apps/vendure README).

# Hide internal products from grids + PDP (still addable by variant id at checkout if needed).
# STOREFRONT_HIDDEN_PRODUCT_SLUGS=gift-box-wrap-card
# STOREFRONT_HIDDEN_PRODUCT_IDS=12

# Optional: address autocomplete on checkout
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here

# Lead/inquiry forms: PostgreSQL + Resend email
# Prefer DATABASE_URL, or reuse Vendure DB_* on App Platform (compose URL automatically).
# DATABASE_URL=postgres://user:password@host:port/hungerhankeringsadmin
# LEADS_DATABASE_NAME=hungerhankeringsadmin
# If unset, falls back to DB_NAME (e.g. vendure). Apply schema: cd storefront && npx prisma migrate deploy
# On DigitalOcean App Platform set DB_SSL_REJECT_UNAUTHORIZED=false (same as Vendure) for TLS to Postgres.
# Optional: LEADS_PG_CONNECT_TIMEOUT_MS=45000 LEADS_PG_POOL_MAX=10
# RESEND_API_KEY=re_xxxx
# LEAD_EMAIL_TO=hello@hungerhankerings.com
# LEAD_EMAIL_FROM=Hunger Hankerings <hello@hungerhankerings.com>
# LEAD_EMAIL_SEND_TIMEOUT_MS=15000
