# Production .env for Droplet + DO Managed Postgres
# Copy this to /root/HungerHankerings/.env on the Droplet, then replace placeholders.

# DO Managed Postgres (replace YOUR_DB_PASSWORD with your actual password)
DATABASE_URL=postgres://doadmin:YOUR_DB_PASSWORD@db-postgresql-tor1-60715-do-user-20752759-0.e.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# Saleor (replace YOUR_SECRET_KEY with a long random string, e.g. openssl rand -hex 32)
SECRET_KEY=YOUR_SECRET_KEY
DEBUG=0
ALLOWED_HOSTS=hungerhankerings.com,api.hungerhankerings.com,admin.hungerhankerings.com

# Email (optional: set when you have SMTP; leave empty or comment out for now)
EMAIL_URL=
DEFAULT_FROM_EMAIL=hello@hungerhankerings.com
