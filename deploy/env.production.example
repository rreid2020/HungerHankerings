# Production .env for Droplet + Vendure
# Copy to /root/HungerHankerings/.env on the Droplet and replace placeholders.
# In dev the droplet may not have the domain yet; when you go to prod, use hungerhankerings.com.
#
# Staging on DigitalOcean: use the same variable names with staging URLs, Stripe test keys (pk_test_),
# and Resend SMTP — see deploy/STAGING-DROPLET.md for a step-by-step checklist.

# PostgreSQL (Vendure). Use DO Managed Postgres or your own.
DB_HOST=db-postgresql-tor1-60715-do-user-20752759-0.e.db.ondigitalocean.com
DB_PORT=25060
DB_USER=doadmin
DB_PASSWORD=your-managed-postgres-password
DB_NAME=vendure
# If DB uses a self-signed cert (e.g. some managed Postgres), set:
# DB_SSL_REJECT_UNAUTHORIZED=false

# Redis (use 'redis' when running in Docker Compose)
REDIS_HOST=redis
REDIS_PORT=6379

# Vendure
COOKIE_SECRET=your-long-random-string
# Set true only when all traffic is HTTPS; if false/unset, session cookies work over HTTP (needed for bare IP testing).
# VENDURE_COOKIE_SECURE=true
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=your-superadmin-password
APP_URL=https://hungerhankerings.com
# Optional: comma-separated extra browser origins allowed by Vendure CORS (staging, preview). Apex + www are added automatically from APP_URL when hostname is a domain name.
# APP_CORS_EXTRA_ORIGINS=https://staging.hungerhankerings.com
NODE_ENV=production

# `/health`: omit DB ping by default (avoids App Platform "Degraded" when TypeORM checks are slow under load).
# Set to true only if you want Vendure’s TypeORM health indicator on `/health`.
# VENDURE_HEALTHCHECK_DATABASE=true

# Vendure channel currency: new installs default to USD; Stripe charges `order.currencyCode`. On boot we set CAD
# when the channel still defaults to USD (idempotent). Set explicitly to force another ISO code, or skip entirely:
# VENDURE_CHANNEL_DEFAULT_CURRENCY=CAD
# SKIP_ENSURE_CHANNEL_DEFAULT_CURRENCY=true
#
# If Admin/Shop error "No price information … in the Channel": variants still need CAD prices.
# One-shot clone USD→CAD (same numeric cents): `npm run backfill:cad-prices-from-usd` in apps/vendure after build (see script header).

# Customer email verification — set false only while testing (sign-up + dashboard without SMTP). Re-enable for launch.
# VENDURE_REQUIRE_EMAIL_VERIFICATION=false

# Storefront (public URL the browser uses for Shop API; same host as storefront with /shop-api path)
NEXT_PUBLIC_VENDURE_SHOP_API_URL=https://hungerhankerings.com/shop-api
# Same public origin as APP_URL — used for server redirects (logout, login) when Host headers are missing/wrong in Docker
NEXT_PUBLIC_SITE_URL=https://hungerhankerings.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Must match Vendure Admin → Payment methods → Stripe method "Code" (storefront API route reads this)
# VENDURE_STRIPE_METHOD_CODE=stripe
# Must match Admin → Dummy payment method "Code" when testing without Stripe
# VENDURE_DUMMY_PAYMENT_METHOD_CODE=dummy-payment-method

# Optional: local asset directory inside the container (still used for temp/cache with Spaces).
# ASSET_UPLOAD_DIR=/app/assets
#
# DigitalOcean Spaces (S3-compatible) — set all four to store uploads in Spaces instead of the Droplet disk.
# Create a Space + API keys: https://cloud.digitalocean.com/spaces — region slug must match the Space (tor1, nyc3, …).
# DO_SPACES_BUCKET=your-space-name
# DO_SPACES_KEY=your_spaces_access_key
# DO_SPACES_SECRET=your_spaces_secret
# DO_SPACES_REGION=tor1

# Email: verification, password reset, and order confirmation. Vendure’s default handlers send order
# confirmation when payment completes — configure SMTP_* below or customers won’t receive emails.
# Without SMTP, account flows show “verify your email” but no message is delivered.
#
# DigitalOcean App Platform (single Docker component): set SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS,
# SMTP_SECURE, SMTP_FROM, and ORDERS_INBOX_EMAIL as RUN_TIME env vars on the component so both Vendure
# and vendure-worker (supervisord) pick them up. Missing SMTP here is the usual reason order emails
# never appear in Resend while other deploy paths work.
#
# Resend (recommended): use your Resend API key via SMTP. Create key at https://resend.com/api-keys;
# verify hungerhankerings.com at https://resend.com/domains so verification emails deliver.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
# SMTP_SECURE=true
# From header — must be allowed in Resend (verify your domain, then e.g. noreply@hungerhankerings.com).
#
# Smoke test (no domain in Resend): use Resend’s test sender only; often delivers to your Resend login email.
# SMTP_FROM=Hunger Hankerings <onboarding@resend.dev>
#
# Production / verified domain:
# SMTP_FROM=Hunger Hankerings <noreply@hungerhankerings.com>
#
# Optional — customer order confirmation (and shared MJML header/footer). Defaults match Hunger Hankerings.
# STORE_DISPLAY_NAME=Hunger Hankerings
# STORE_EMAIL_TAGLINE=Artisan treats and gifts delivered across Canada
#
# Store inbox copy when payment settles: by default that address is **BCC** on the customer order confirmation
# (same email body as the customer — reliable single SMTP send). Defaults to orders@hungerhankerings.com if unset.
# ORDERS_INBOX_EMAIL=orders@hungerhankerings.com
#
# Use a separate “[New order]” email + custom MJML template instead of BCC (two sends; only if you need it):
# ORDERS_INBOX_SEPARATE_EMAIL=true
#
# Resend: until hungerhankerings.com is verified, outbound mail may only reach limited test recipients —
# verify the domain at https://resend.com/domains so orders@ and customer addresses both deliver.
#
# After deploy, check logs: docker compose ... logs vendure-worker | head -50
# You should see: "[vendure] EmailPlugin: SMTP enabled (smtp.resend.com:465, user=resend)"
# If you see "SMTP not configured" or "dropped", fix .env and recreate containers.
# If you registered BEFORE SMTP worked, that account never got an email — register again with a new address
# or confirm the customer in Vendure Admin (Customers).
#
# --- Contact / lead form (storefront /api/leads → ops DB + Resend) ---
# Same Postgres cluster as Vendure; use the ops database name (not DB_NAME / vendure).
# DATABASE_URL=postgres://doadmin:PASSWORD@PRIVATE-HOST:25060/hungerhankeringsadmin
# Reuse DB_SSL_REJECT_UNAUTHORIZED=false on this component (see storefront lib/db.ts).
# Run once: psql "$DATABASE_URL" -f storefront/scripts/init-leads-db.sql
# RESEND_API_KEY=re_xxxx
# LEAD_EMAIL_TO=hello@hungerhankerings.com
# LEAD_EMAIL_FROM=Hunger Hankerings <hello@hungerhankerings.com>
#
# --- Staff ops subdomain (optional; nginx → Next.js on :3001 — build custom admin in storefront) ---
# Staff ops portal (nginx INTERNAL_OPS_HOST + same hostname for Next). Set both to the ops FQDN.
# INTERNAL_OPS_HOST=ops.hungerhankerings.com
# NEXT_PUBLIC_OPS_HOST=ops.hungerhankerings.com
# NEXT_PUBLIC_OPS_HOST is BUILD_TIME in Docker — pass docker build --build-arg NEXT_PUBLIC_OPS_HOST=ops.hungerhankerings.com (or set in App Platform build env) so middleware can redirect / → /ops on the ops host.
# Add ops.* to App domains + DNS. Remove any old Directus-only env (ENABLE_DIRECTUS, PUBLIC_URL for Directus, KEY/SECRET, DB_DATABASE for Directus) from the component.
#
# Ops portal auth (Clerk) — separate from Vendure customer sessions (different host recommended).
# BUILD_TIME: NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY (same Docker build-arg pattern as NEXT_PUBLIC_OPS_HOST).
# RUN_TIME: CLERK_SECRET_KEY on the web component. Without both, production returns 503 for / and /ops on the ops host.
# Optional redirects (defaults work with path-based /ops/sign-in): NEXT_PUBLIC_CLERK_SIGN_IN_URL, NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL
