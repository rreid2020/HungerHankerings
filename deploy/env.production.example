# Production .env for Droplet + Vendure
# Copy to /root/HungerHankerings/.env on the Droplet and replace placeholders.
# In dev the droplet may not have the domain yet; when you go to prod, use hungerhankerings.com.

# PostgreSQL (Vendure). Use DO Managed Postgres or your own.
DB_HOST=your-db-host.example.com
DB_PORT=25060
DB_USER=doadmin
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=vendure
# If DB uses a self-signed cert (e.g. some managed Postgres), set:
# DB_SSL_REJECT_UNAUTHORIZED=false

# Redis (use 'redis' when running in Docker Compose)
REDIS_HOST=redis
REDIS_PORT=6379

# Vendure
COOKIE_SECRET=your-long-random-string
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=your-superadmin-password
APP_URL=https://hungerhankerings.com
NODE_ENV=production

# Storefront (public URL the browser uses for Shop API; same host as storefront with /shop-api path)
NEXT_PUBLIC_VENDURE_SHOP_API_URL=https://hungerhankerings.com/shop-api
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Optional: asset storage
# ASSET_UPLOAD_DIR=/app/assets

# Email (verification and password-reset). Required for account verification emails to be sent.
# Without these, customers will see "verify your email" but never receive the link.
#
# Resend (recommended): use your Resend API key via SMTP. Create key at https://resend.com/api-keys;
# verify hungerhankerings.com at https://resend.com/domains so verification emails deliver.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
# SMTP_SECURE=true
