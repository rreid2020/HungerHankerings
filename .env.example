# Root .env for Docker Compose and deploy. Copy to .env and fill in.
# See deploy/env.production.example for production variables.

# Vendure (used by apps/vendure in Docker)
DB_HOST=localhost
DB_PORT=55432
DB_USER=vendure
DB_PASSWORD=vendure
DB_NAME=vendure
REDIS_HOST=localhost
REDIS_PORT=6379
COOKIE_SECRET=dev-cookie-secret
APP_URL=http://localhost:3000
# Set false to skip customer email verification (local / dev testing only)
# VENDURE_REQUIRE_EMAIL_VERIFICATION=false

# Vendure defaults the shop channel to USD; this repo ensures CAD on boot when still USD (see apps/vendure ensure-channel-default-currency).
# VENDURE_CHANNEL_DEFAULT_CURRENCY=CAD
# SKIP_ENSURE_CHANNEL_DEFAULT_CURRENCY=true

# Storefront (build / runtime)
NEXT_PUBLIC_VENDURE_SHOP_API_URL=http://localhost:3000/shop-api
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Server-only: timeout (ms) for each Shop API fetch from Next.js API routes (checkout does many round-trips). Default 30000 in compose; max 120000 in code.
# VENDURE_SERVER_FETCH_TIMEOUT_MS=30000

# Production / staging droplet: set SMTP_* and APP_URL for registration, password reset, and receipts
# (see deploy/env.production.example, deploy/STAGING-DROPLET.md, storefront/docs/CUSTOMER-ACCOUNTS.md).

# --- Local Mailpit (optional) ---
# Docker Compose includes Mailpit (web UI http://localhost:8025). To route Vendure mail there (verification, password reset, internal orders inbox):
#   SMTP_HOST=mailpit
#   SMTP_PORT=1025
# Leave SMTP_USER and SMTP_PASS empty (Mailpit accepts unauthenticated SMTP).
# Internal new-order notifications use ORDERS_INBOX_EMAIL (shown as To: in Mailpit; default orders@hungerhankerings.com).
# ORDERS_INBOX_EMAIL=orders@hungerhankerings.com
# If SMTP_HOST is unset in development, Vendure uses the built-in /mailbox dev capture instead of Mailpit.

# Optional: force storefront order/confirmation currency (ISO 4217), e.g. if Vendure channel reports USD but prices are CAD.
# NEXT_PUBLIC_STORE_CURRENCY=CAD
