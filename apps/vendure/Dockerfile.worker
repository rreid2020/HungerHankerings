# Worker image: server + worker code only (no Admin UI build — saves time and memory).
FROM node:20-alpine AS builder

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .
RUN npm run build

FROM node:20-alpine

WORKDIR /app

COPY package.json ./
RUN npm install --omit=dev

COPY --from=builder /app/dist ./dist
RUN mkdir -p /app/assets

ENV NODE_ENV=production

CMD ["node", "dist/worker.js"]
