{{> header title="New store order" }}

<mj-section background-color="#f5f5f5">
  <mj-column>
    <mj-text>
      <strong>Order:</strong> {{ order.code }}<br/>
      {{#if order.orderPlacedAt}}<strong>Placed:</strong> {{ formatDate order.orderPlacedAt }}<br/>{{/if}}
      <strong>State:</strong> {{ order.state }}<br/>
      <strong>Currency:</strong> {{ order.currencyCode }}
    </mj-text>
  </mj-column>
</mj-section>

<mj-section background-color="#f5f5f5">
  <mj-column>
    <mj-text>
      {{#if order.customer}}
      <strong>Customer:</strong> {{ order.customer.firstName }} {{ order.customer.lastName }} &lt;{{ order.customer.emailAddress }}&gt;<br/>
      {{else}}
      <strong>Customer:</strong> Guest checkout (no customer record on order)<br/>
      {{#if order.shippingAddress}}
      <strong>Ship-to name:</strong> {{ order.shippingAddress.fullName }}<br/>
      {{#if order.shippingAddress.phoneNumber}}<strong>Phone:</strong> {{ order.shippingAddress.phoneNumber }}<br/>{{/if}}
      {{/if}}
      {{/if}}
    </mj-text>
  </mj-column>
</mj-section>

<mj-section>
  <mj-column>
    <mj-text font-size="16px" font-weight="bold">Line items</mj-text>
    {{#each order.lines}}
    <mj-text padding-top="4px">
      {{ productVariant.product.name }} — {{ productVariant.name }} × {{ quantity }}
      {{#if productVariant.sku}}<br/><span style="color:#666">SKU: {{ productVariant.sku }}</span>{{/if}}
      <br/><span style="color:#666">Line total (incl. tax): {{ formatMoney discountedLinePriceWithTax order.currencyCode 'en-CA' }}</span>
    </mj-text>
    {{/each}}
  </mj-column>
</mj-section>

{{#if order.discounts}}
<mj-section background-color="#fafafa">
  <mj-column>
    <mj-text font-size="16px" font-weight="bold">Discounts</mj-text>
    {{#each order.discounts}}
    <mj-text padding-top="4px">{{ description }}: {{ formatMoney amount ../order.currencyCode 'en-CA' }}</mj-text>
    {{/each}}
  </mj-column>
</mj-section>
{{/if}}

{{#if order.couponCodes}}
<mj-section background-color="#fafafa">
  <mj-column>
    <mj-text><strong>Coupon codes:</strong> {{#each order.couponCodes}}{{ this }}{{#unless @last}}, {{/unless}}{{/each}}</mj-text>
  </mj-column>
</mj-section>
{{/if}}

{{#if order.taxSummary}}
<mj-section>
  <mj-column>
    <mj-text font-size="16px" font-weight="bold">Tax</mj-text>
    {{#each order.taxSummary}}
    <mj-text padding-top="4px">
      {{ description }} (rate {{ taxRate }}) — base {{ formatMoney taxBase ../order.currencyCode 'en-CA' }}, tax {{ formatMoney taxTotal ../order.currencyCode 'en-CA' }}
    </mj-text>
    {{/each}}
  </mj-column>
</mj-section>
{{/if}}

<mj-section background-color="#fafafa">
  <mj-column>
    <mj-text><strong>Totals</strong></mj-text>
    <mj-text padding-top="4px">
      Subtotal (ex. tax): {{ formatMoney order.subTotal order.currencyCode 'en-CA' }}<br/>
      Subtotal (incl. tax): {{ formatMoney order.subTotalWithTax order.currencyCode 'en-CA' }}<br/>
      {{#each shippingLines}}
      Shipping ({{ shippingMethod.name }}): {{ formatMoney price ../order.currencyCode 'en-CA' }} (ex.) / {{ formatMoney priceWithTax ../order.currencyCode 'en-CA' }} (incl. tax)<br/>
      {{else}}
      Shipping (ex. tax): {{ formatMoney order.shipping order.currencyCode 'en-CA' }}<br/>
      Shipping (incl. tax): {{ formatMoney order.shippingWithTax order.currencyCode 'en-CA' }}<br/>
      {{/each}}
      {{#if giftFeeMinor}}
      Gift packaging (add-on, tax-inclusive minor units): {{ formatMoney giftFeeMinor order.currencyCode 'en-CA' }}<br/>
      {{/if}}
      <strong>Total (incl. tax):</strong> {{ formatMoney order.totalWithTax order.currencyCode 'en-CA' }}
    </mj-text>
  </mj-column>
</mj-section>

{{#if order.payments}}
<mj-section>
  <mj-column>
    <mj-text font-size="16px" font-weight="bold">Payments</mj-text>
    {{#each order.payments}}
    <mj-text padding-top="4px">
      {{ state }} — {{ method }}: {{ formatMoney amount ../order.currencyCode 'en-CA' }}
    </mj-text>
    {{/each}}
  </mj-column>
</mj-section>
{{/if}}

{{#if giftLines}}
<mj-section background-color="#fff8e6">
  <mj-column>
    <mj-text font-size="16px" font-weight="bold">Gift messages (per item / box)</mj-text>
    {{#each giftLines}}
    <mj-text padding-top="8px">
      <strong>{{ lineLabel }}</strong>
      <br/><span style="white-space:pre-wrap">{{ message }}</span>
    </mj-text>
    {{/each}}
  </mj-column>
</mj-section>
{{/if}}

<mj-section>
  <mj-column>
    {{#with order.shippingAddress}}
    <mj-text><strong>Ship to</strong><br/>
      {{#if company}}{{ company }}<br/>{{/if}}
      {{ fullName }}<br/>
      {{ streetLine1 }}{{#if streetLine2}}<br/>{{ streetLine2 }}{{/if}}<br/>
      {{ city }}, {{ province }} {{ postalCode }}<br/>
      {{ country }}
      {{#if phoneNumber}}<br/>{{ phoneNumber }}{{/if}}
    </mj-text>
    {{/with}}
  </mj-column>
</mj-section>

{{#with order.billingAddress}}
<mj-section background-color="#f9f9f9">
  <mj-column>
    <mj-text><strong>Bill to</strong><br/>
      {{#if company}}{{ company }}<br/>{{/if}}
      {{ fullName }}<br/>
      {{ streetLine1 }}{{#if streetLine2}}<br/>{{ streetLine2 }}{{/if}}<br/>
      {{ city }}, {{ province }} {{ postalCode }}<br/>
      {{ country }}
      {{#if phoneNumber}}<br/>{{ phoneNumber }}{{/if}}
    </mj-text>
  </mj-column>
</mj-section>
{{/with}}

{{> footer }}
