{
  "name": "vendure",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/plugins/shipping-plugin/ui', 'dist/plugins/shipping-plugin/ui', {recursive:true})\"",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "migrate": "node migrate-bootstrap.js",
