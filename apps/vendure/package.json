  "devDependencies": {
    "@nestjs/graphql": "~12.2.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.11.0",
    "graphql": "~16.9.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
