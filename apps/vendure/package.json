    "@vendure/ui-devkit": "^2.1.0",
    "@vendure/email-plugin": "^2.1.0",
    "@vendure/payments-plugin": "^2.1.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.0",
    "pg": "^8.11.0",
    "stripe": "^13.0.0",
    "typeorm": "0.3.11"
  },
  "devDependencies": {
    "@nestjs/common": "10.2.1",
    "@nestjs/graphql": "^12.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.10.0",
    "graphql": "^16.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
