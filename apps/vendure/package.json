    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "migrate": "node migrate-bootstrap.js",
    "add-stripe-column": "node dist/add-stripe-customer-column.js",
    "add-stripe-column-order-order-customer": "node dist/add-stripe-column-order-order-customer.js",
    "fix-stripe-column-casing": "node dist/fix-stripe-customer-column-casing.js",
    "add-stripe-column-any-customer-table": "node dist/add-stripe-column-any-customer-table.js",
    "add-stripe-column-exact-name": "node dist/add-stripe-column-exact-name.js",
    "seed:canadian-tax": "node dist/seed-canadian-tax-zones.js",
